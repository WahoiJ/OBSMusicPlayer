<Window x:Class="OBSMusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OBS Music Player" Height="640" Width="620"
        MinWidth="500" Background="#1E1E2E"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#CBA6F7"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <!-- Now Playing -->
        <Border Grid.Row="0" Background="#181825" CornerRadius="8" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="♪ Now Playing" Foreground="#CBA6F7" FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="NowPlayingText" Text="---" Foreground="White"
                               FontSize="17" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="DurationText" Text="" Foreground="#6C7086" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Ellipse x:Name="ObsStatusDot" Width="10" Height="10" Fill="#F38BA8" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock x:Name="ObsStatusText" Text="OBS 未接続" Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10" Width="280">
            <Button x:Name="PlayStopButton" Content="▶  再生" Width="130" Height="40" Margin="5"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold" FontSize="14"
                    Click="PlayStopButton_Click"/>
            <Button x:Name="SkipButton" Content="⏭  スキップ" Width="130" Height="40" Margin="5"
                    FontSize="14" Click="SkipButton_Click"/>
        </StackPanel>

        <!-- Settings -->
        <GroupBox Grid.Row="2" Header="⚙  設定" Margin="0,0,0,10">
            <Grid Margin="10,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><!-- 音量行 -->
                    <RowDefinition Height="Auto"/><!-- 保存ボタン -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="OBS URL" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox x:Name="ObsUrlBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="6,5,0,5" Height="26"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="OBS パスワード" VerticalAlignment="Center" Margin="0,5"/>
                <PasswordBox x:Name="ObsPasswordBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="6,5,0,5" Height="26"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="音楽フォルダ" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox x:Name="MusicFolderBox" Grid.Row="2" Grid.Column="1" Margin="6,5,4,5" Height="26" IsReadOnly="True"/>
                <Button Grid.Row="2" Grid.Column="2" Content="📁" Width="32" Height="26"
                        Click="BrowseFolderButton_Click" ToolTip="フォルダを選択"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="OBS テキスト名" VerticalAlignment="Center" Margin="0,5"/>
                <TextBox x:Name="SourceTextBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="6,5,0,5" Height="26"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="履歴割合" VerticalAlignment="Center" Margin="0,5"/>
                <Slider x:Name="HistoryRatioSlider" Grid.Row="4" Grid.Column="1"
                        Minimum="0" Maximum="1" SmallChange="0.1" LargeChange="0.1"
                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                        Margin="6,5,6,5" VerticalAlignment="Center"
                        ValueChanged="HistoryRatioSlider_ValueChanged"/>
                <TextBlock x:Name="HistoryRatioLabel" Grid.Row="4" Grid.Column="2"
                           Text="0.5" Width="28" VerticalAlignment="Center" TextAlignment="Center"/>

                <!-- 音量スライダー（Row 5） -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="🔊 音量" VerticalAlignment="Center" Margin="0,5"/>
                <Slider x:Name="VolumeSlider" Grid.Row="5" Grid.Column="1"
                        Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                        TickFrequency="0.05" IsSnapToTickEnabled="False"
                        Margin="6,5,6,5" VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged"/>
                <TextBlock x:Name="VolumeLabel" Grid.Row="5" Grid.Column="2"
                           Text="70%" Width="28" VerticalAlignment="Center" TextAlignment="Center"/>

                <!-- 保存ボタン（Row 6） -->
                <Button Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                        Content="設定を保存して接続" Height="34" Margin="0,10,0,2"
                        Background="#89DCEB" Foreground="#1E1E2E" FontWeight="Bold"
                        Click="SaveSettingsButton_Click"/>
            </Grid>
        </GroupBox>

        <!-- Log -->
        <GroupBox Grid.Row="3" Header="📋  ログ">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" Foreground="#A6ADC8" FontFamily="Consolas"
                           FontSize="11" TextWrapping="Wrap" Margin="4"/>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>